DATABASE_URL=postgresql://username:password@host:port/defaultdb?sslmode=require
DATABASE_SSL_REJECT_UNAUTHORIZED=false
# Optional CA bundle string (advanced):
# DATABASE_SSL_CA=-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----

GROQ_API_KEY=gsk_...
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=meta-llama/llama-4-maverick-17b-128e-instruct
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1

TELEGRAM_BOT_TOKEN=123456:ABCDEF...
TELEGRAM_WEBHOOK_SECRET=optional_random_secret

WHATSAPP_VERIFY_TOKEN=your_webhook_verify_token
WHATSAPP_ACCESS_TOKEN=your_meta_permanent_access_token
WHATSAPP_PHONE_NUMBER_ID=923763520829508
WHATSAPP_API_VERSION=v21.0
WHATSAPP_APP_SECRET=your_meta_app_secret

DEFAULT_CURRENCY=IDR
DEFAULT_TIMEZONE=Asia/Jakarta

OCR_LANGS=eng+ind
MAX_UPLOAD_MB=2
ANOMALY_LOOKBACK_DAYS=60
# Optional: CDN base for Tesseract worker/core (avoids bundling issues)
TESSERACT_CDN_BASE=https://cdn.jsdelivr.net/npm/tesseract.js@5.1.0/dist
AGENT_MAX_ACTIONS=3
AGENT_HISTORY_LIMIT=10
AGENT_MAX_TOKENS=8000
AGENT_ERROR_BUDGET=3
AGENT_DEBUG_LOG=0
VECTOR_DIM=1536
EMBEDDING_MODEL=
HF_TOKEN=
HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# Optional custom inference URL; otherwise built from HF_EMBEDDING_MODEL
# HF_INFERENCE_URL=
PENDING_TTL_MINUTES=15
